# Docker Swarm 集群环境变量配置
# 复制此文件为 .env 并填入实际值

# Tailscale Auth Key (必填)
# 获取方式: https://login.tailscale.com/admin/settings/keys
TS_AUTH_KEY=tskey-auth-xxxxx-xxxxx

# GitHub Personal Access Token (必填)
# 获取方式: https://github.com/settings/tokens
# 权限: repo, workflow, codespace
GH_PAT=ghp_xxxxxxxxxxxxxxxxxxxx

# GitHub 仓库 (自动检测，通常无需修改)
GITHUB_REPOSITORY=your-username/your-repo

# 节点生命周期 (秒)
# 默认 19800 = 5.5小时
# Codespaces 6小时自动销毁，提前30分钟交班
LIFETIME=19800

# GlusterFS 配置
GLUSTER_VOLUME_NAME=workflow-data
GLUSTER_MOUNT_POINT=/mnt/gluster
