# Docker Swarm 集群环境变量配置
# 复制此文件为 .env 并填入实际值

# ===========================================
# 必填配置
# ===========================================

# Tailscale Auth Key (必填)
# 获取方式: https://login.tailscale.com/admin/settings/keys
TS_AUTH_KEY=tskey-auth-kUZjSi5yXA11CNTRL-axBMdddsfr1RLyofEJJ5r1FtAoVVXuC9e

# GitHub Personal Access Token (必填)
# 获取方式: https://github.com/settings/tokens
# 权限: repo, workflow, codespace
GH_PAT=ghp_xxxxxxxxxxxxxxxxxxxx

# ===========================================
# 系统用户配置
# ===========================================

# 系统用户名 (root用户)
CLUSTER_USER=root

# 系统用户密码
CLUSTER_PASSWORD=root123456

# SSH公钥 (可选，用于免密登录)
# SSH_PUBLIC_KEY=ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAI... user@example.com

# ===========================================
# 集群配置
# ===========================================

# GitHub 仓库 (自动检测，通常无需修改)
GITHUB_REPOSITORY=yuu76hy/asd

# 节点生命周期 (秒)
# 默认 19800 = 5.5小时
# Codespaces 6小时自动销毁，提前30分钟交班
LIFETIME=19800

# GlusterFS 配置
GLUSTER_VOLUME_NAME=workflow-data
GLUSTER_MOUNT_POINT=/mnt/gluster

# ===========================================
# 节点IP配置 (Tailscale)
# ===========================================

DOCKER1_IP=100.64.0.1
DOCKER2_IP=100.64.0.2
DOCKER3_IP=100.64.0.3
DOCKER4_IP=100.64.0.4
DOCKER5_IP=100.64.0.5
